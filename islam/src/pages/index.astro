---
import Layout from "../layouts/Layout.astro";
import PrayerTimes from "../components/PrayerTimes.astro";
import QiblaCompass from "../components/QiblaCompass.astro";
---

<Layout title="Prayer Times &amp; Qibla Compass — Islam">
  <!-- Date display (populated client-side to respect timezone) -->
  <div class="text-center mb-6">
    <p class="text-lg text-gray-700 dark:text-gray-300" id="gregorian-date">--</p>
    <p class="text-sm text-gray-500 dark:text-gray-400" id="hijri-date">--</p>
  </div>

  <!-- Location request button (hidden by default, shown only if permission denied) -->
  <div id="location-request" hidden class="flex flex-col items-center gap-4 mt-8">
    <p class="text-gray-600 dark:text-gray-400 text-center" data-i18n="location.allowPrompt">
      Allow location access to see prayer times and Qibla direction for your area.
    </p>
    <button id="request-location-btn" class="px-6 py-3 bg-primary-600 hover:bg-primary-700 text-white font-medium rounded-lg transition-colors shadow-sm" data-i18n="location.requestBtn">
      Request Location
    </button>
  </div>

  <!-- Error message (hidden by default) -->
  <div id="location-error" hidden class="mt-6 flex flex-col items-center gap-4">
    <p class="text-red-600 dark:text-red-400 text-center" id="location-error-msg" data-i18n="location.errorDefault">
      Unable to access your location. Please check your browser permissions and try again.
    </p>
    <button id="retry-location-btn" class="px-4 py-2 bg-gray-200 dark:bg-gray-800 hover:bg-gray-300 dark:hover:bg-gray-700 text-gray-700 dark:text-gray-300 rounded-lg transition-colors" data-i18n="location.retryBtn">
      Retry
    </button>
  </div>

  <!-- Next prayer countdown (shared — visible above tabs) -->
  <div id="next-prayer-card" hidden class="bg-primary-600 text-white rounded-xl shadow-sm p-4 mb-4 text-center">
    <p class="text-sm opacity-90" data-i18n="card.nextPrayer">Next prayer</p>
    <p id="next-prayer-name" class="text-2xl font-bold mt-1">--</p>
    <p id="next-prayer-countdown" class="text-3xl font-mono mt-2 tabular-nums">--:--:--</p>
  </div>

  <!-- Tab bar -->
  <div role="tablist" class="flex border-b border-gray-200 dark:border-gray-700 mb-4">
    <button id="tab-btn-prayer-times" role="tab" aria-selected="true" class="flex-1 py-3 px-4 text-sm font-medium text-primary-700 dark:text-primary-400 border-b-2 border-primary-600 transition-colors" data-i18n="tabs.prayerTimes">
      Prayer Times
    </button>
    <button id="tab-btn-qibla" role="tab" aria-selected="false" class="flex-1 py-3 px-4 text-sm font-medium text-gray-500 dark:text-gray-400 border-b-2 border-transparent hover:text-gray-700 dark:hover:text-gray-300 transition-colors md:hidden" data-i18n="tabs.qibla">
      Qibla
    </button>
  </div>

  <!-- Tab panels -->
  <div id="tab-panel-prayer-times" role="tabpanel">
    <PrayerTimes />
  </div>
  <div id="tab-panel-qibla" role="tabpanel" hidden>
    <QiblaCompass />
  </div>

  <!-- App scripts -->
  <script>
    import "../scripts/app";
  </script>
</Layout>

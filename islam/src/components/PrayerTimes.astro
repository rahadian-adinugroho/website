---
// Prayer times display component
// Renders 6 prayer times + next prayer countdown
// Hidden by default, shown via JS after geolocation
---

<div id="prayer-times" hidden class="mt-6">
  <!-- Prayer times list -->
  <div class="bg-white dark:bg-gray-900 rounded-xl shadow-sm border border-gray-200 dark:border-gray-800 overflow-hidden">
    <div class="px-4 py-3 border-b border-gray-200 dark:border-gray-800">
      <h2 class="text-lg font-semibold text-gray-900 dark:text-gray-100">Prayer Times</h2>
    </div>
    <div class="divide-y divide-gray-100 dark:divide-gray-800">
      <div id="prayer-row-fajr" class="flex items-center justify-between px-4 py-3 transition-colors">
        <span class="text-gray-700 dark:text-gray-300">Fajr</span>
        <span id="prayer-time-fajr" class="text-gray-900 dark:text-gray-100 font-mono">--:--</span>
      </div>
      <div id="prayer-row-sunrise" class="flex items-center justify-between px-4 py-3 transition-colors">
        <span class="text-gray-700 dark:text-gray-300">Sunrise</span>
        <span id="prayer-time-sunrise" class="text-gray-900 dark:text-gray-100 font-mono">--:--</span>
      </div>
      <!-- Dhuha (sunnah, hidden by default) -->
      <div id="prayer-row-dhuha" class="flex items-center justify-between px-4 py-3 transition-colors hidden">
        <span class="text-gray-500 dark:text-gray-400 italic">Dhuha</span>
        <span id="prayer-time-dhuha" class="text-gray-700 dark:text-gray-300 font-mono">--:--</span>
      </div>
      <div id="prayer-row-dhuhr" class="flex items-center justify-between px-4 py-3 transition-colors">
        <span class="text-gray-700 dark:text-gray-300">Dhuhr</span>
        <span id="prayer-time-dhuhr" class="text-gray-900 dark:text-gray-100 font-mono">--:--</span>
      </div>
      <div id="prayer-row-asr" class="flex items-center justify-between px-4 py-3 transition-colors">
        <span class="text-gray-700 dark:text-gray-300">Asr</span>
        <span id="prayer-time-asr" class="text-gray-900 dark:text-gray-100 font-mono">--:--</span>
      </div>
      <div id="prayer-row-maghrib" class="flex items-center justify-between px-4 py-3 transition-colors">
        <span class="text-gray-700 dark:text-gray-300">Maghrib</span>
        <span id="prayer-time-maghrib" class="text-gray-900 dark:text-gray-100 font-mono">--:--</span>
      </div>
      <div id="prayer-row-isha" class="flex items-center justify-between px-4 py-3 transition-colors">
        <span class="text-gray-700 dark:text-gray-300">Isha</span>
        <span id="prayer-time-isha" class="text-gray-900 dark:text-gray-100 font-mono">--:--</span>
      </div>
      <!-- Sunnah prayers (hidden by default, shown via JS) -->
      <div id="prayer-row-middleOfNight" class="flex items-center justify-between px-4 py-3 transition-colors hidden">
        <span class="text-gray-500 dark:text-gray-400 italic">Middle of the Night</span>
        <span id="prayer-time-middleOfNight" class="text-gray-700 dark:text-gray-300 font-mono">--:--</span>
      </div>
      <div id="prayer-row-lastThirdOfNight" class="flex items-center justify-between px-4 py-3 transition-colors hidden">
        <span class="text-gray-500 dark:text-gray-400 italic">Last Third of the Night</span>
        <span id="prayer-time-lastThirdOfNight" class="text-gray-700 dark:text-gray-300 font-mono">--:--</span>
      </div>
    </div>
  </div>
</div>

---
// Settings bottom sheet / modal panel
// Visibility is controlled by JS — the panel starts hidden
// and opens via the settings gear icon in the header.
---

<div id="settings-panel" class="fixed inset-0 z-50" hidden aria-modal="true" role="dialog" aria-labelledby="settings-title">
  <!-- Backdrop -->
  <div id="settings-backdrop" class="absolute inset-0 bg-black/50 dark:bg-black/60"></div>

  <!-- Panel -->
  <div id="settings-container" class="absolute bottom-0 left-0 right-0 md:relative md:max-w-md md:mx-auto md:my-8 bg-white dark:bg-gray-900 rounded-t-2xl md:rounded-2xl shadow-xl max-h-[85vh] flex flex-col transition-transform duration-300 ease-out">

    <!-- Header -->
    <div class="flex items-center justify-between px-6 py-4 border-b border-gray-200 dark:border-gray-800 shrink-0">
      <h2 id="settings-title" class="text-lg font-semibold text-gray-900 dark:text-gray-100" data-i18n="settings.title">Settings</h2>
      <button id="settings-close-btn" type="button" class="text-gray-400 hover:text-gray-600 dark:hover:text-gray-300 transition-colors" aria-label="Close settings" data-i18n-aria-label="aria.closeSettings">
        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
        </svg>
      </button>
    </div>

    <!-- Body (scrollable) -->
    <div class="overflow-y-auto p-6 space-y-6">
      <!-- Section: Notifications -->
      <section>
        <h3 class="text-sm font-semibold text-gray-500 dark:text-gray-400 uppercase tracking-wide mb-3" data-i18n="settings.notifications">Notifications</h3>
        <div class="space-y-1">
          <button id="enable-notifications-btn" type="button" class="w-full px-3 py-2 text-sm bg-primary-600 hover:bg-primary-700 text-white rounded-lg transition-colors" data-i18n="settings.enableNotifications">
            Enable Notifications
          </button>
          <p id="enable-notifications-error" class="hidden mt-2 text-sm text-red-600 dark:text-red-400" role="alert"></p>
          <p id="notification-prefs-hint" class="text-xs text-gray-400 dark:text-gray-500 mt-2">
            Enable notifications to choose which prayers.
          </p>
          <div id="notification-prefs" class="space-y-1 mt-2">
            <label class="settings-option flex items-center gap-3 py-2 cursor-pointer opacity-50">
              <input type="checkbox" name="notify-fajr" checked disabled class="accent-primary-600 shrink-0" />
              <span class="text-sm text-gray-900 dark:text-gray-100" data-i18n="prayer.fajr">Fajr</span>
            </label>
            <label class="settings-option flex items-center gap-3 py-2 cursor-pointer opacity-50">
              <input type="checkbox" name="notify-dhuhr" checked disabled class="accent-primary-600 shrink-0" />
              <span class="text-sm text-gray-900 dark:text-gray-100" data-i18n="prayer.dhuhr">Dhuhr</span>
            </label>
            <label class="settings-option flex items-center gap-3 py-2 cursor-pointer opacity-50">
              <input type="checkbox" name="notify-asr" checked disabled class="accent-primary-600 shrink-0" />
              <span class="text-sm text-gray-900 dark:text-gray-100" data-i18n="prayer.asr">Asr</span>
            </label>
            <label class="settings-option flex items-center gap-3 py-2 cursor-pointer opacity-50">
              <input type="checkbox" name="notify-maghrib" checked disabled class="accent-primary-600 shrink-0" />
              <span class="text-sm text-gray-900 dark:text-gray-100" data-i18n="prayer.maghrib">Maghrib</span>
            </label>
            <label class="settings-option flex items-center gap-3 py-2 cursor-pointer opacity-50">
              <input type="checkbox" name="notify-isha" checked disabled class="accent-primary-600 shrink-0" />
              <span class="text-sm text-gray-900 dark:text-gray-100" data-i18n="prayer.isha">Isha</span>
            </label>
          </div>
        </div>
      </section>

      <!-- Section: Language -->
      <section>
        <h3 class="text-sm font-semibold text-gray-500 dark:text-gray-400 uppercase tracking-wide mb-3" data-i18n="settings.language">Language</h3>
        <select name="settings-lang" class="w-full px-3 py-2 text-sm bg-white dark:bg-gray-800 border border-gray-300 dark:border-gray-700 rounded-lg focus:ring-2 focus:ring-primary-500 focus:border-primary-500">
          <option value="auto" data-i18n="settings.lang.auto">Automatic</option>
          <option value="id" data-i18n="settings.lang.id">Bahasa Indonesia</option>
          <option value="en" data-i18n="settings.lang.en">English</option>
        </select>
      </section>

      <!-- Section: Calculation Method -->
      <section>
        <h3 class="text-sm font-semibold text-gray-500 dark:text-gray-400 uppercase tracking-wide mb-3" data-i18n="settings.calcMethod">Calculation Method</h3>
        <select name="settings-calc-method" class="w-full px-3 py-2 text-sm bg-white dark:bg-gray-800 border border-gray-300 dark:border-gray-700 rounded-lg focus:ring-2 focus:ring-primary-500 focus:border-primary-500">
          <option value="automatic" data-i18n="settings.calcMethod.automatic">Automatic</option>
          <option value="singapore" data-i18n="settings.calcMethod.singapore">Singapore / Kemenag</option>
          <option value="ummAlQura" data-i18n="settings.calcMethod.ummAlQura">Umm al-Qura</option>
          <option value="muslimWorldLeague" data-i18n="settings.calcMethod.muslimWorldLeague">Muslim World League</option>
          <option value="egyptian" data-i18n="settings.calcMethod.egyptian">Egyptian</option>
          <option value="karachi" data-i18n="settings.calcMethod.karachi">Karachi</option>
          <option value="northAmerica" data-i18n="settings.calcMethod.northAmerica">North America (ISNA)</option>
          <option value="tehran" data-i18n="settings.calcMethod.tehran">Tehran</option>
          <option value="turkey" data-i18n="settings.calcMethod.turkey">Turkey (Diyanet)</option>
        </select>
        <p id="settings-detected-method" class="text-xs text-gray-400 dark:text-gray-500 mt-2">Using: --</p>
      </section>

      <!-- Section: Sunnah Prayers -->
      <section>
        <h3 class="text-sm font-semibold text-gray-500 dark:text-gray-400 uppercase tracking-wide mb-3" data-i18n="settings.sunnahPrayers">Sunnah Prayers</h3>
        <div class="space-y-1">
          <label class="settings-option flex items-center gap-3 py-2 cursor-pointer" data-sunnah="dhuha">
            <input type="checkbox" name="settings-sunnah-dhuha" class="accent-primary-600 shrink-0" />
            <span class="text-sm text-gray-900 dark:text-gray-100" data-i18n="prayer.dhuha">Dhuha</span>
          </label>
          <label class="settings-option flex items-center gap-3 py-2 cursor-pointer" data-sunnah="middleOfNight">
            <input type="checkbox" name="settings-sunnah-middleOfNight" class="accent-primary-600 shrink-0" />
            <span class="text-sm text-gray-900 dark:text-gray-100" data-i18n="prayer.middleOfNight">Middle of the Night</span>
          </label>
          <label class="settings-option flex items-center gap-3 py-2 cursor-pointer" data-sunnah="lastThirdOfNight">
            <input type="checkbox" name="settings-sunnah-lastThirdOfNight" class="accent-primary-600 shrink-0" />
            <span class="text-sm text-gray-900 dark:text-gray-100" data-i18n="prayer.lastThirdOfNight">Last Third of the Night</span>
          </label>
        </div>
      </section>
    </div>
  </div>
</div>

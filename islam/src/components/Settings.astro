---
// Settings bottom sheet / modal panel
// Visibility is controlled by JS — the panel starts hidden
// and opens via the settings gear icon in the header.
---

<div id="settings-panel" class="fixed inset-0 z-50" hidden aria-modal="true" role="dialog" aria-labelledby="settings-title">
  <!-- Backdrop -->
  <div id="settings-backdrop" class="absolute inset-0 bg-black/50 dark:bg-black/60"></div>

  <!-- Panel -->
  <div id="settings-container" class="absolute bottom-0 left-0 right-0 md:relative md:max-w-md md:mx-auto md:my-8 bg-white dark:bg-gray-900 rounded-t-2xl md:rounded-2xl shadow-xl max-h-[85vh] flex flex-col transform translate-y-0 transition-transform duration-300 ease-out">
    <!-- Drag handle (mobile) -->
    <div class="md:hidden w-12 h-1.5 bg-gray-300 dark:bg-gray-600 rounded-full mx-auto mt-3"></div>

    <!-- Header -->
    <div class="flex items-center justify-between px-6 py-4 border-b border-gray-200 dark:border-gray-800 shrink-0">
      <h2 id="settings-title" class="text-lg font-semibold text-gray-900 dark:text-gray-100">Settings</h2>
      <button id="settings-close-btn" type="button" class="text-gray-400 hover:text-gray-600 dark:hover:text-gray-300 transition-colors" aria-label="Close settings">
        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
        </svg>
      </button>
    </div>

    <!-- Body (scrollable) -->
    <div class="overflow-y-auto p-6 space-y-6">
      <!-- Section: Calculation Method -->
      <section>
        <h3 class="text-sm font-semibold text-gray-500 dark:text-gray-400 uppercase tracking-wide mb-3">Calculation Method</h3>

        <div class="space-y-1">
          <!-- Automatic -->
          <label class="settings-option flex items-center gap-3 py-2 cursor-pointer" data-method="automatic">
            <input type="radio" name="settings-calc-method" value="automatic" checked class="accent-primary-600 shrink-0" />
            <div class="flex flex-col">
              <span class="text-sm text-gray-900 dark:text-gray-100">Automatic</span>
              <span id="settings-detected-method" class="text-xs text-gray-400 dark:text-gray-500">Using: --</span>
            </div>
          </label>

          <!-- Explicit methods -->
          <label class="settings-option flex items-center gap-3 py-2 cursor-pointer" data-method="singapore">
            <input type="radio" name="settings-calc-method" value="singapore" class="accent-primary-600 shrink-0" />
            <span class="text-sm text-gray-900 dark:text-gray-100">Singapore / Kemenag</span>
          </label>
          <label class="settings-option flex items-center gap-3 py-2 cursor-pointer" data-method="ummAlQura">
            <input type="radio" name="settings-calc-method" value="ummAlQura" class="accent-primary-600 shrink-0" />
            <span class="text-sm text-gray-900 dark:text-gray-100">Umm al-Qura</span>
          </label>
          <label class="settings-option flex items-center gap-3 py-2 cursor-pointer" data-method="muslimWorldLeague">
            <input type="radio" name="settings-calc-method" value="muslimWorldLeague" class="accent-primary-600 shrink-0" />
            <span class="text-sm text-gray-900 dark:text-gray-100">Muslim World League</span>
          </label>
          <label class="settings-option flex items-center gap-3 py-2 cursor-pointer" data-method="egyptian">
            <input type="radio" name="settings-calc-method" value="egyptian" class="accent-primary-600 shrink-0" />
            <span class="text-sm text-gray-900 dark:text-gray-100">Egyptian</span>
          </label>
          <label class="settings-option flex items-center gap-3 py-2 cursor-pointer" data-method="karachi">
            <input type="radio" name="settings-calc-method" value="karachi" class="accent-primary-600 shrink-0" />
            <span class="text-sm text-gray-900 dark:text-gray-100">Karachi</span>
          </label>
          <label class="settings-option flex items-center gap-3 py-2 cursor-pointer" data-method="northAmerica">
            <input type="radio" name="settings-calc-method" value="northAmerica" class="accent-primary-600 shrink-0" />
            <span class="text-sm text-gray-900 dark:text-gray-100">North America (ISNA)</span>
          </label>
          <label class="settings-option flex items-center gap-3 py-2 cursor-pointer" data-method="tehran">
            <input type="radio" name="settings-calc-method" value="tehran" class="accent-primary-600 shrink-0" />
            <span class="text-sm text-gray-900 dark:text-gray-100">Tehran</span>
          </label>
        </div>
      </section>

      <!-- Section: Prayer Times -->
      <section>
        <h3 class="text-sm font-semibold text-gray-500 dark:text-gray-400 uppercase tracking-wide mb-3">Prayer Times</h3>
        <div id="settings-prayer-times-list" class="divide-y divide-gray-100 dark:divide-gray-800">
          <!-- Populated by JS -->
        </div>
      </section>

      <!-- Section: Sunnah Prayers -->
      <section>
        <h3 class="text-sm font-semibold text-gray-500 dark:text-gray-400 uppercase tracking-wide mb-3">Sunnah Prayers</h3>
        <div class="space-y-1">
          <label class="settings-option flex items-center justify-between py-2 cursor-pointer" data-sunnah="dhuha">
            <div class="flex items-center gap-3">
              <input type="checkbox" name="settings-sunnah-dhuha" class="accent-primary-600 shrink-0" />
              <span class="text-sm text-gray-900 dark:text-gray-100">Dhuha</span>
            </div>
            <span id="settings-dhuha-time" class="text-xs text-gray-400 dark:text-gray-500 font-mono">--:--</span>
          </label>
          <label class="settings-option flex items-center justify-between py-2 cursor-pointer" data-sunnah="middleOfNight">
            <div class="flex items-center gap-3">
              <input type="checkbox" name="settings-sunnah-middleOfNight" class="accent-primary-600 shrink-0" />
              <span class="text-sm text-gray-900 dark:text-gray-100">Middle of the Night</span>
            </div>
            <span id="settings-middleOfNight-time" class="text-xs text-gray-400 dark:text-gray-500 font-mono">--:--</span>
          </label>
          <label class="settings-option flex items-center justify-between py-2 cursor-pointer" data-sunnah="lastThirdOfNight">
            <div class="flex items-center gap-3">
              <input type="checkbox" name="settings-sunnah-lastThirdOfNight" class="accent-primary-600 shrink-0" />
              <span class="text-sm text-gray-900 dark:text-gray-100">Last Third of the Night</span>
            </div>
            <span id="settings-lastThirdOfNight-time" class="text-xs text-gray-400 dark:text-gray-500 font-mono">--:--</span>
          </label>
        </div>
      </section>
    </div>
  </div>
</div>

<style>
  /* Slide-up animation when panel becomes visible */
  #settings-panel:not([hidden]) #settings-container {
    transform: translateY(0);
  }
</style>

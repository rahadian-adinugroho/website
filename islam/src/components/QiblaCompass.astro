---
// Qibla compass component
// Circular compass with directional arrow
// Hidden on desktop (md:hidden)
// Hidden by default, shown via JS after geolocation
---

<div id="qibla-compass" hidden class="mt-8 md:hidden">
  <div class="flex flex-col items-center">
    <h2 class="text-lg font-semibold text-gray-900 dark:text-gray-100 mb-4" data-i18n="qibla.heading">Qibla Compass</h2>
    <div class="relative w-48 h-48 rounded-full bg-gray-100 dark:bg-gray-800 border-4 border-gray-300 dark:border-gray-700 flex items-center justify-center">
      <!-- Compass rose cardinal points -->
      <span class="absolute top-2 text-xs text-gray-500 dark:text-gray-400">📱</span>

      <!-- Arrow -->
      <svg id="qibla-arrow" class="w-32 h-32" viewBox="0 0 100 100" style="transform: rotate(0deg); will-change: transform;">
        <!-- Arrow pointing up (toward Qibla) -->
        <polygon points="50,10 35,50 45,50 45,90 55,90 55,50 65,50" fill="#16a34a" />
      </svg>

      <!-- Center dot -->
      <div class="absolute w-3 h-3 rounded-full bg-primary-600 dark:bg-primary-400"></div>
    </div>
    <p class="mt-3 text-sm text-gray-600 dark:text-gray-400" data-i18n="qibla.label">Qibla</p>

    <!-- Accuracy fine-print button (always visible, shows guide on tap) -->
    <button id="accuracy-fine-print" class="mt-1 text-xs text-gray-400 dark:text-gray-500 hover:text-gray-600 dark:hover:text-gray-300 transition-colors underline underline-offset-2 cursor-pointer" data-i18n="qibla.aboutAccuracy">
      About accuracy
    </button>

    <!-- Prominent figure-8 calibration guide (iOS, shown when accuracy > 20°) -->
    <div id="accuracy-guide-prominent" hidden class="mt-4 p-4 bg-amber-50 dark:bg-amber-900/20 border border-amber-200 dark:border-amber-800 rounded-lg w-full max-w-xs">
      <div class="flex flex-col items-center gap-2">
        <svg viewBox="0 0 200 100" class="w-48 h-24 overflow-visible">
          <!-- Dashed guide path (figure-8 / lemniscate) -->
          <path d="M 30 50 C 50 20, 80 20, 100 50 C 120 80, 150 80, 170 50 C 150 20, 120 20, 100 50 C 80 80, 50 80, 30 50 Z"
                fill="none" stroke="currentColor" stroke-width="1.5" stroke-dasharray="4 4"
                class="text-gray-400 dark:text-gray-500" />
          <!-- Phone icon tracing the path -->
          <rect x="-12" y="-8" width="24" height="16" rx="3" fill="#16a34a" opacity="0.9">
            <animateMotion id="prominent-guide-anim" begin="indefinite" dur="3s" repeatCount="indefinite" rotate="auto"
              path="M 30 50 C 50 20, 80 20, 100 50 C 120 80, 150 80, 170 50 C 150 20, 120 20, 100 50 C 80 80, 50 80, 30 50 Z" />
          </rect>
        </svg>
        <p class="text-xs text-gray-600 dark:text-gray-400 text-center" data-i18n="qibla.calibrationGuide">
          Move your phone in a figure-8 pattern to calibrate the compass. This helps the device map the local magnetic field.
        </p>
      </div>
    </div>

    <!-- Modal for Android (shown on fine-print click) -->
    <div id="accuracy-guide-modal" hidden class="fixed inset-0 z-50 flex items-center justify-center">
      <!-- Backdrop -->
      <div id="accuracy-guide-backdrop" class="absolute inset-0 bg-black/50 dark:bg-black/60"></div>
      <!-- Modal content -->
      <div class="relative z-10 bg-white dark:bg-gray-800 rounded-xl p-6 mx-4 max-w-sm w-full shadow-xl">
        <div class="flex items-start justify-between mb-4">
          <h3 class="text-sm font-semibold text-gray-900 dark:text-gray-100" data-i18n="qibla.calibrationTitle">Compass Calibration</h3>
          <button id="accuracy-guide-close" type="button" class="text-gray-400 hover:text-gray-600 dark:hover:text-gray-300 transition-colors" aria-label="Close calibration guide" data-i18n-aria-label="aria.closeCalibration">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
            </svg>
          </button>
        </div>
        <div class="flex flex-col items-center gap-3">
          <svg viewBox="0 0 200 100" class="w-48 h-24 overflow-visible">
            <!-- Dashed guide path -->
            <path d="M 30 50 C 50 20, 80 20, 100 50 C 120 80, 150 80, 170 50 C 150 20, 120 20, 100 50 C 80 80, 50 80, 30 50 Z"
                  fill="none" stroke="currentColor" stroke-width="1.5" stroke-dasharray="4 4"
                  class="text-gray-400 dark:text-gray-500" />
            <!-- Phone icon tracing the path -->
            <rect x="-12" y="-8" width="24" height="16" rx="3" fill="#16a34a" opacity="0.9">
              <animateMotion id="modal-guide-anim" begin="indefinite" dur="3s" repeatCount="indefinite" rotate="auto"
                path="M 30 50 C 50 20, 80 20, 100 50 C 120 80, 150 80, 170 50 C 150 20, 120 20, 100 50 C 80 80, 50 80, 30 50 Z" />
            </rect>
          </svg>
          <p class="text-xs text-gray-600 dark:text-gray-400 text-center" data-i18n="qibla.calibrationGuide">
            Move your phone in a figure-8 pattern to calibrate the compass. This helps the device map the local magnetic field.
          </p>
        </div>
      </div>
    </div>

    <!-- iOS permission button (hidden on non-iOS) -->
    <button id="compass-permission-btn" hidden class="mt-4 px-4 py-2 bg-primary-600 hover:bg-primary-700 text-white rounded-lg text-sm transition-colors" data-i18n="qibla.enableCompass">
      Enable Compass
    </button>
  </div>
</div>

<script>
  const guideProminent = document.getElementById("accuracy-guide-prominent");
  const finePrint = document.getElementById("accuracy-fine-print");
  const modal = document.getElementById("accuracy-guide-modal");
  const modalClose = document.getElementById("accuracy-guide-close");
  const modalBackdrop = document.getElementById("accuracy-guide-backdrop");
  const prominentAnim = document.getElementById("prominent-guide-anim");
  const modalAnim = document.getElementById("modal-guide-anim");

  const isIOS =
    typeof DeviceOrientationEvent !== "undefined" &&
    typeof (DeviceOrientationEvent as any).requestPermission === "function";

  function startAnim(anim: HTMLElement | null) {
    if (anim && typeof (anim as any).beginElement === "function") {
      (anim as any).beginElement();
    }
  }

  function stopAnim(anim: HTMLElement | null) {
    if (anim && typeof (anim as any).endElement === "function") {
      (anim as any).endElement();
    }
  }

  // --- iOS: live accuracy updates toggle prominent guide ---
  if (isIOS && guideProminent) {
    window.addEventListener("qibla:accuracy", ((e: CustomEvent) => {
      const isInaccurate = e.detail.accuracy > 20;
      guideProminent.hidden = !isInaccurate;
      if (isInaccurate) {
        startAnim(prominentAnim);
      } else {
        stopAnim(prominentAnim);
      }
    }) as EventListener);
  }

  // --- Stop animations when Qibla tab is hidden ---
  // The <animateMotion> elements have repeatCount="indefinite", so once
  // started they loop forever. Even when the parent element is hidden
  // via display:none, the animation timeline continues, causing
  // continuous repaints and CPU drain on iOS Safari.
  window.addEventListener("qibla:tab-hidden", () => {
    stopAnim(prominentAnim);
    stopAnim(modalAnim);
  });

  // --- Modal open/close (shared for both platforms) ---
  if (finePrint && modal && modalClose && modalBackdrop) {
    function openModal() {
      modal.hidden = false;
      document.body.style.overflow = "hidden";
      startAnim(modalAnim);
      // Focus the close button for accessibility
      requestAnimationFrame(() => modalClose!.focus());
    }

    function closeModal() {
      modal.hidden = true;
      document.body.style.overflow = "";
      stopAnim(modalAnim);
    }

    finePrint.addEventListener("click", openModal);
    modalClose.addEventListener("click", closeModal);
    modalBackdrop.addEventListener("click", closeModal);
    modal.addEventListener("keydown", (e: KeyboardEvent) => {
      if (e.key === "Escape") closeModal();
    });
  }
</script>

---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Rahadian Adinugroho" description="Senior Software Engineer at Traveloka. I design and build scalable backend systems.">
  <div class="flex items-center justify-center min-h-screen px-4">
    <div class="w-full max-w-sm text-center">
      <img
        src="/img/profile.jpg"
        alt="Rahadian Adinugroho"
        class="w-32 h-32 rounded-full mx-auto mb-8 ring-1 ring-zinc-200"
      />
      
      <h1 class="text-3xl font-bold mb-2">
        Rahadian Adinugroho
      </h1>
      
      <p class="text-sm text-zinc-600 mb-4">
        Senior Software Engineer · <a href="https://www.traveloka.com/en-id" class="hover:text-zinc-900 transition-colors">Traveloka</a>
      </p>
      
      <p class="text-zinc-700 text-sm leading-relaxed mb-8">
        I design and build scalable backend systems. Currently at Traveloka.
      </p>
      
      <div class="space-y-3 mb-8">
        <a
          href="https://www.linkedin.com/in/rahadian-adinugroho/"
          class="block px-4 py-2 rounded-full border border-zinc-300 text-sm text-zinc-700 hover:bg-zinc-50 hover:border-zinc-400 transition-colors"
        >
          LinkedIn
        </a>
        <a
          href="https://github.com/rahadian-adinugroho"
          class="block px-4 py-2 rounded-full border border-zinc-300 text-sm text-zinc-700 hover:bg-zinc-50 hover:border-zinc-400 transition-colors"
        >
          GitHub
        </a>
        <a
          href="mailto:rahadian@raharoho.me"
          class="block px-4 py-2 rounded-full border border-zinc-300 text-sm text-zinc-700 hover:bg-zinc-50 hover:border-zinc-400 transition-colors"
        >
          Email
        </a>
        <a
          href="https://blog.raharoho.me"
          class="block px-4 py-2 rounded-full border border-zinc-900 bg-zinc-900 text-sm text-white hover:bg-zinc-800 hover:border-zinc-800 transition-colors font-medium"
        >
          Blog →
        </a>
      </div>
    </div>
  </div>
</Layout>

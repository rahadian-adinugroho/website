---
interface Props {
  title: string;
  description: string;
  type?: string;
  publishedTime?: Date;
}

const { title, description, type = 'website', publishedTime } = Astro.props;
const canonicalURL = new URL(Astro.url.pathname, Astro.site);
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta name="robots" content="index, follow" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="canonical" href={canonicalURL} />
    <title>{title}</title>
    <meta property="og:type" content={type} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    {publishedTime && (
      <meta property="og:article:published_time" content={publishedTime.toISOString()} />
    )}
    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
  </head>
  <body class="bg-zinc-50 text-zinc-800 min-h-screen">
    <header class="border-b border-zinc-200 bg-white">
      <nav class="max-w-2xl mx-auto px-4 py-4 flex items-center justify-between">
        <a href="/" class="font-semibold text-zinc-900 hover:text-zinc-600 transition-colors">
          Rahadian's Blog
        </a>
        <a
          href="https://raharoho.me"
          class="text-sm text-zinc-500 hover:text-zinc-700 transition-colors"
        >
          ← raharoho.me
        </a>
      </nav>
    </header>
    <main class="max-w-2xl mx-auto px-4 py-10">
      <slot />
    </main>
    <footer class="border-t border-zinc-200 mt-16">
      <div class="max-w-2xl mx-auto px-4 py-6 text-center text-sm text-zinc-400 space-y-2">
        <p>© {new Date().getFullYear()} Rahadian Adinugroho</p>
        <p>All opinions expressed here are my own and do not represent my employer.</p>
        <a
          href="https://github.com/rahadian-adinugroho/website"
          target="_blank"
          rel="noopener noreferrer"
          class="hover:text-zinc-600 transition-colors"
        >
          View source on GitHub
        </a>
      </div>
    </footer>
  </body>
</html>

---
import { getCollection } from 'astro:content';
import Layout from '../layouts/Layout.astro';

const allPosts = await getCollection('posts', ({ data }) => !data.draft);
const posts = allPosts.sort((a, b) => b.data.date.getTime() - a.data.date.getTime());
---
<Layout
  title="Rahadian's Blog"
  description="Writing about software engineering, systems design, and things I find interesting."
>
  <header class="mb-10">
    <h1 class="text-3xl font-bold text-zinc-900">All Posts</h1>
    <p class="mt-2 text-zinc-500">Thoughts on engineering and beyond.</p>
  </header>

  {posts.length === 0 ? (
    <p class="text-zinc-500">No posts yet. Check back soon.</p>
  ) : (
    <ul class="space-y-8">
      {posts.map((post) => (
        <li>
          <a href={`/posts/${post.slug}`} class="group block">
            <article>
              <time
                class="text-sm text-zinc-400"
                datetime={post.data.date.toISOString()}
              >
                {post.data.date.toLocaleDateString('en-US', {
                  year: 'numeric',
                  month: 'long',
                  day: 'numeric',
                })}
              </time>
              <h2 class="mt-1 text-xl font-semibold text-zinc-900 group-hover:text-zinc-600 transition-colors">
                {post.data.title}
              </h2>
              <p class="mt-1 text-zinc-500 text-sm leading-relaxed">
                {post.data.description}
              </p>
            </article>
          </a>
        </li>
      ))}
    </ul>
  )}
</Layout>

---
import { getCollection } from 'astro:content';
import Layout from '../layouts/Layout.astro';

const CATEGORY_LABELS: Record<string, string> = {
  'engineering-web-apps': 'Engineering: Web Apps',
  'engineering-networking': 'Engineering: Networking',
  'traveling': 'Traveling',
  'automotive': 'Automotive',
};

const allPosts = await getCollection('posts', ({ data }) => !data.draft);
const posts = allPosts.sort((a, b) => b.data.date.getTime() - a.data.date.getTime());

const grouped = new Map<string, typeof posts>();
for (const post of posts) {
  const key = post.data.category ?? '__uncategorized__';
  if (!grouped.has(key)) grouped.set(key, []);
  grouped.get(key)!.push(post);
}

// Order: known categories first (in defined order), uncategorized last
const orderedKeys = [
  ...Object.keys(CATEGORY_LABELS).filter((k) => grouped.has(k)),
  ...(grouped.has('__uncategorized__') ? ['__uncategorized__'] : []),
];
---
<Layout
  title="Rahadian's Blog"
  description="Writing about software engineering, systems design, and things I find interesting."
>
  <header class="mb-10">
    <h1 class="text-3xl font-bold text-zinc-900">All Posts</h1>
    <p class="mt-2 text-zinc-500">Thoughts on engineering and beyond.</p>
  </header>

  {posts.length === 0 ? (
    <p class="text-zinc-500">No posts yet. Check back soon.</p>
  ) : (
    <div class="space-y-12">
      {orderedKeys.map((key) => {
        const label = key === '__uncategorized__' ? 'Uncategorized' : CATEGORY_LABELS[key];
        const categoryPosts = grouped.get(key)!;
        return (
          <section>
            <h2 class="text-xs font-semibold uppercase tracking-widest text-zinc-400 mb-4 pb-2 border-b border-zinc-200">
              {key === '__uncategorized__' ? label : (
                <a href={`/category/${key}`} class="hover:text-zinc-600 transition-colors">{label}</a>
              )}
            </h2>
            <ul class="space-y-8">
              {categoryPosts.map((post) => (
                <li>
                  <a href={`/posts/${post.slug}`} class="group block">
                    <article>
                      <time
                        class="text-sm text-zinc-400"
                        datetime={post.data.date.toISOString()}
                      >
                        {post.data.date.toLocaleDateString('en-US', {
                          year: 'numeric',
                          month: 'long',
                          day: 'numeric',
                        })}
                      </time>
                      <h3 class="mt-1 text-xl font-semibold text-zinc-900 group-hover:text-zinc-600 transition-colors">
                        {post.data.title}
                      </h3>
                      <p class="mt-1 text-zinc-500 text-sm leading-relaxed">
                        {post.data.description}
                      </p>
                    </article>
                  </a>
                </li>
              ))}
            </ul>
          </section>
        );
      })}
    </div>
  )}
</Layout>
